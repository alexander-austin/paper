{
    "version": 1,
    "disable_existing_loggers": false,
    "formatters": {
        "generic": {
            "format": "%(asctime)s | %(name)s - %(levelname)s : %(message)s"
        }
    },
    "handlers": {
        "display_handler": {
            "level": "DEBUG",
            "class": "logging.FileHandler",
            "formatter": "generic"
        },
        "gpinput_handler": {
            "level": "DEBUG",
            "class": "logging.FileHandler",
            "formatter": "generic"
        },
        "imager_handler": {
            "level": "DEBUG",
            "class": "logging.FileHandler",
            "formatter": "generic"
        },
        "mpu6050_handler": {
            "level": "DEBUG",
            "class": "logging.FileHandler",
            "formatter": "generic"
        }
    },
    "loggers": {
        "display": {
            "level": "DEBUG",
            "handlers": [
                "display_handler"
            ]
        },
        "gpinput": {
            "level": "DEBUG",
            "handlers": [
                "gpinput_handler"
            ]
        },
        "imager": {
            "level": "DEBUG",
            "handlers": [
                "imager_handler"
            ]
        },
        "mpu6050": {
            "level": "DEBUG",
            "handlers": [
                "mpu6050_handler"
            ]
        }
    }
}